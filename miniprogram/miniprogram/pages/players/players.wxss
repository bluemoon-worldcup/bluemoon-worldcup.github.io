.team-head {
  display: flex;
  align-items: center;
  margin: 36rpx 32rpx 16rpx;
}
.team-flag { font-size: 44rpx; }
.t-name { font-size: 32rpx; font-weight: 700; margin-left: 20rpx; }
.t-group {
  font-size: 22rpx;
  color: #6cabdd;
  border: 1rpx solid #3d6a8a;
  border-radius: 16rpx;
  padding: 2rpx 16rpx;
  margin-left: 16rpx;
}
.t-count { margin-left: auto; font-size: 23rpx; color: #97a0ad; }

.plist { padding: 8rpx 28rpx; }
.player-row {
  display: flex;
  align-items: center;
  padding: 18rpx 4rpx;
  border-bottom: 1rpx solid #2e3440;
}
.player-row:last-child { border-bottom: none; }
.p-num {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #262b35;
  color: #6cabdd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 28rpx;
  flex-shrink: 0;
}
.p-num.dim { background: transparent; font-size: 36rpx; }
.p-main { flex: 1; min-width: 0; margin-left: 24rpx; }
.p-name { font-size: 30rpx; font-weight: 600; }
.p-name.dim { color: #97a0ad; }
.p-en { font-size: 23rpx; color: #97a0ad; }
.p-pos { font-size: 24rpx; color: #97a0ad; flex-shrink: 0; }
.tag-departed {
  font-size: 21rpx;
  color: #f0a020;
  border: 1rpx solid rgba(240, 160, 32, 0.5);
  border-radius: 16rpx;
  padding: 0 12rpx;
  margin-left: 12rpx;
  font-weight: 400;
}
.warn { color: #f0a020; }
